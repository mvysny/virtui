#!/usr/bin/env ruby
# frozen_string_literal: true

# Add lib/ to the load path
$LOAD_PATH.unshift File.expand_path('../lib', __dir__)

require 'bundler/setup'

require 'tuile'
require 'tty-logger'
require 'rainbow'
require 'virt/virt'
require 'virt/virtcache'
require 'virt/ballooning'
require 'virt/vm_emulator'
require 'app_layout'

# https://github.com/piotrmurach/tty-logger
$log = TTY::Logger.new do |config|
  config.level = :info
end
Tuile.logger = $log

# Update terminal title to show "VirTUI"
print "\e]0;VirTUI\a"

# Don't use LibVirtClient for now: it doesn't provide all necessary data
# virt = LibVirtClient.new
virt = VirtCmd.new if VirtCmd.available?
virt ||= VMEmulator.demo
virt_cache = VirtCache.new(virt, SysInfo.new)

ballooning = Ballooning.new(virt_cache)
screen = Tuile::Screen.new
screen.on_error = ->(e) { $log.fatal('Uncaught event loop exception', e) }
layout = AppLayout.new(virt_cache, ballooning)
screen.content = layout
screen.focused = layout.vms

scheduler = Concurrent::TimerTask.new(execution_interval: 2, interval_type: :fixed_rate) do
  virt_cache.update
  screen.event_queue.submit do
    ballooning.update
    layout.update_data
  end
rescue StandardError => e
  $log.fatal('Failed to update VM data', e)
end
begin
  scheduler.execute
  screen.run_event_loop
ensure
  scheduler.shutdown
  screen.close
end
