#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'

require 'tty-logger'
require_relative '../lib/virtui'

# https://github.com/piotrmurach/tty-logger
$log = TTY::Logger.new do |config|
  config.level = :info
end
Tuile.logger = $log

# Update terminal title to show "VirTUI"
print "\e]0;VirTUI\a"

# Don't use Virt::LibVirtClient for now: it doesn't provide all necessary data
# virt = Virt::LibVirtClient.new
virt = Virt::Virsh.new if Virt::Virsh.available?
virt ||= Virt::VMEmulator.demo
virt_cache = Virt::Cache.new(virt, System::Info.new)

ballooning = Virt::Ballooning.new(virt_cache)
screen = Tuile::Screen.new
screen.theme_def = UI::Theme::THEME_DEF
screen.on_error = ->(e) { $log.fatal('Uncaught event loop exception', e) }
layout = UI::AppLayout.new(virt_cache, ballooning)
screen.content = layout
screen.focused = layout.vms

scheduler = Concurrent::TimerTask.new(execution_interval: 2, interval_type: :fixed_rate) do
  virt_cache.update
  screen.event_queue.submit do
    ballooning.update
    layout.update_data
  end
rescue StandardError => e
  $log.fatal('Failed to update VM data', e)
end
begin
  scheduler.execute
  screen.run_event_loop
ensure
  scheduler.shutdown
  screen.close
end
